def garantir_config_modo_janela_arquivos():
    try:
        if not os.path.exists(CAMINHO_BATOCERA):
            return
        with open(CAMINHO_BATOCERA, "r") as f:
            conteudo = f.read()
        if "CONFIGS_MODO_JANELA" not in conteudo:
            if "TEMPO_MENU_SEGUNDOS" in conteudo:
                conteudo = re.sub(
                    r"(TEMPO_MENU_SEGUNDOS\s*=\s*\d+)",
                    r"\1\nCONFIGS_MODO_JANELA = false",
                    conteudo
                )
            elif "PIX_VALOR" in conteudo:
                conteudo = re.sub(
                    r"(PIX_VALOR\s*=\s*\S+)",
                    r"\1\nCONFIGS_MODO_JANELA = false",
                    conteudo
                )
            else:
                conteudo += "\nCONFIGS_MODO_JANELA = false\n"
            with open(CAMINHO_BATOCERA, "w") as f:
                f.write(conteudo)
    except Exception as e:
        print(f"Erro ao garantir CONFIGS_MODO_JANELA: {e}")

def verificar_modo_janela_arquivos():
    try:
        if os.path.exists(CAMINHO_BATOCERA):
            with open(CAMINHO_BATOCERA, "r") as f:
                for linha in f:
                    if "CONFIGS_MODO_JANELA" in linha:
                        valor = linha.split("=")[-1].strip().lower()
                        return valor == "true"
    except:
        pass
    return False


