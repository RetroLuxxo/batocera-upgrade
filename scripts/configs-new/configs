    # --- FUNÇÕES PIX (ASAAS / MERCADO PAGO) ---
    def load_pix_configs(self):
        """Apenas lê e respeita o batocera.conf, sem salvar ou alterar ao inicializar."""
        asaas_ativo = False
        mp_ativo = False
        try:
            with open(CAMINHO_BATOCERA, "r") as f:
                for linha in f:
                    linha_limpa = linha.strip().upper()
                    
                    if linha_limpa.startswith("PIX_ASAAS") and not linha_limpa.startswith("PIX_ASAAS_STATIC"):
                        asaas_ativo = "TRUE" in linha_limpa.split("=")[-1]
                        
                    elif linha_limpa.startswith("PIX_MERCADO_PAGO"):
                        mp_ativo = "TRUE" in linha_limpa.split("=")[-1]
                        
        except Exception as e:
            print(f"Erro ao carregar configs do PIX: {e}")

        # Apenas reflete o que foi encontrado no arquivo
        self.asaas_var.set(asaas_ativo)
        self.mercado_pago_var.set(mp_ativo)
        
        # RASTREADOR: Memoriza o gateway atual para evitar reinício desnecessário
        if asaas_ativo:
            self.gateway_atual = "asaas"
        elif mp_ativo:
            self.gateway_atual = "mercadopago"
        else:
            self.gateway_atual = None

    def aplicar_arquivos_pix(self, gateway):
        """Mata o processo atual, remove o arquivo, copia (cp -f) o novo e executa."""
        self.parar_processo(FBNEO_TARGET)

        if os.path.exists(FBNEO_TARGET):
            try:
                os.remove(FBNEO_TARGET)
            except Exception as e:
                print(f"Aviso ao remover {FBNEO_TARGET}: {e}")
        
        try:
            if gateway == "asaas" and os.path.exists(FBNEO_ASAAS_SRC):
                subprocess.run(["cp", "-f", FBNEO_ASAAS_SRC, FBNEO_TARGET], check=True)
            elif gateway == "mercadopago" and os.path.exists(FBNEO_MP_SRC):
                subprocess.run(["cp", "-f", FBNEO_MP_SRC, FBNEO_TARGET], check=True)
                
            if os.path.exists(FBNEO_TARGET):
                subprocess.run(["chmod", "+x", FBNEO_TARGET])
                subprocess.Popen([FBNEO_TARGET], cwd=BIN_DIR)
        except Exception as e:
            msgbox.showerror("Erro", f"Erro ao aplicar script PIX ({gateway}):\n{e}")

    def toggle_asaas(self):
        # Mantém a caixa asaas forçada como verdadeira visualmente
        self.asaas_var.set(True)
        self.mercado_pago_var.set(False)
        
        # Só reinicia e salva se o gateway realmente for alterado
        if getattr(self, 'gateway_atual', None) != "asaas":
            self.gateway_atual = "asaas"
            self.salvar_estado_pix()
            self.aplicar_arquivos_pix("asaas")

    def toggle_mercado_pago(self):
        # Mantém a caixa mercado pago forçada como verdadeira visualmente
        self.mercado_pago_var.set(True)
        self.asaas_var.set(False)
        
        # Só reinicia e salva se o gateway realmente for alterado
        if getattr(self, 'gateway_atual', None) != "mercadopago":
            self.gateway_atual = "mercadopago"
            self.salvar_estado_pix()
            self.aplicar_arquivos_pix("mercadopago")

    def salvar_estado_pix(self):
        valor_asaas = "true" if self.asaas_var.get() else "false"
        valor_mp = "true" if self.mercado_pago_var.get() else "false"

        try:
            with open(CAMINHO_BATOCERA, "r") as f:
                conteudo = f.read()

            conteudo = re.sub(r"\bPIX_ASAAS\s*=\s*(true|false)", f"PIX_ASAAS = {valor_asaas}", conteudo, flags=re.IGNORECASE)
            conteudo = re.sub(r"\bPIX_MERCADO_PAGO\s*=\s*(true|false)", f"PIX_MERCADO_PAGO = {valor_mp}", conteudo, flags=re.IGNORECASE)

            with open(CAMINHO_BATOCERA, "w") as f:
                f.write(conteudo)
                
        except Exception as e:
            msgbox.showerror("Erro", f"Erro ao salvar configurações de PIX:\n{e}")

    # --- CENTRALIZAR 640x480 ---
    def centralizar_janela(self):
        largura = 680
        altura = 480
        x = (self.winfo_screenwidth() // 2) - (largura // 2)
        y = (self.winfo_screenheight() // 2) - (altura // 2)
        self.geometry(f"{largura}x{altura}+{x}+{y}")

    # --- Garante CONFIGS_MODO_JANELA existe ---
    def garantir_config_modo_janela(self):
        try:
            with open(CAMINHO_BATOCERA, "r") as f:
                conteudo = f.read()
            if "CONFIGS_MODO_JANELA" not in conteudo:
                if "TEMPO_MENU_SEGUNDOS" in conteudo:
                    conteudo = re.sub(
                        r"(TEMPO_MENU_SEGUNDOS\s*=\s*\d+)",
                        r"\1\nCONFIGS_MODO_JANELA = false",
                        conteudo
                    )
                else:
                    conteudo += "\nCONFIGS_MODO_JANELA = false\n"
                with open(CAMINHO_BATOCERA, "w") as f:
                    f.write(conteudo)
        except Exception as e:
            msgbox.showerror("Erro", f"Erro ao garantir CONFIGS_MODO_JANELA:\n{e}")

    # --- Lê e retorna True se CONFIGS_MODO_JANELA = true ---
    def verificar_modo_janela(self):
        try:
            with open(CAMINHO_BATOCERA, "r") as f:
                for linha in f:
                    if "CONFIGS_MODO_JANELA" in linha:
                        valor = linha.split("=")[-1].strip().lower()
                        return valor == "true"
        except:
            pass
        return False

    # --- Alterna true/false no arquivo ao marcar/desmarcar ---
    def toggle_modo_janela(self):
        try:
            valor = "true" if self.modo_janela_var.get() else "false"
            with open(CAMINHO_BATOCERA, "r") as f:
                conteudo = f.read()
            if "CONFIGS_MODO_JANELA" in conteudo:
                conteudo = re.sub(r"(CONFIGS_MODO_JANELA\s*=\s*)(true|false)", f"\\1{valor}", conteudo)
            else:
                conteudo += f"\nCONFIGS_MODO_JANELA = {valor}\n"
            with open(CAMINHO_BATOCERA, "w") as f:
                f.write(conteudo)
            self.destroy()
            app = ConfiguradorApp()
            app.mainloop()
        except Exception as e:
            msgbox.showerror("Erro", f"Erro ao alterar CONFIGS_MODO_JANELA:\n{e}")

    # --- LOADS EXISTENTES ---
    def load_lista_unica(self):
        self.lista_unica_var.set(os.path.exists(CAMINHO_ES_SYSTEMS))

    def toggle_lista_unica(self):
        try:
            subprocess.run(["lista_unica"], check=True)
        except:
            pass

    def load_menu_comercial(self):
        self.menu_comercial_var.set(os.path.exists(CAMINHO_MENU_COMERCIAL))

    def toggle_menu_comercial(self):
        try:
            one = PROCESSO_ONE
            six = PROCESSO_SIX
            one_bak = one + ".bak"

            self.parar_processo(one)
            self.parar_processo(six)

            if self.menu_comercial_var.get():
                os.makedirs(os.path.dirname(CAMINHO_MENU_COMERCIAL), exist_ok=True)
                open(CAMINHO_MENU_COMERCIAL, "w").close()

                if os.path.exists(one) and not os.path.exists(one_bak):
                    os.rename(one, one_bak)

                if os.path.exists(six):
                    subprocess.run(["cp", six, one])
                    subprocess.run(["chmod", "+x", one])
            else:
                if os.path.exists(one):
                    os.remove(one)

                if os.path.exists(one_bak):
                    os.rename(one_bak, one)

                if os.path.exists(CAMINHO_MENU_COMERCIAL):
                    os.remove(CAMINHO_MENU_COMERCIAL)

            self.iniciar_processo(one)

        except Exception as e:
            msgbox.showerror("Erro", str(e))

    def load_modo_comercial_desativado(self):
        self.modo_comercial_atual = False
        try:
            with open(CAMINHO_BATOCERA, "r") as f:
                for linha in f:
                    if "MODO_COMERCIAL_DESATIVADO" in linha:
                        valor = linha.split("=")[-1].strip()
                        estado = (valor == "1")
                        self.modo_comercial_desativado_var.set(estado)
                        # RASTREADOR: Memoriza se estava "Free" (True) ou "Comercial" (False)
                        self.modo_comercial_atual = estado
                        return
        except:
            pass
        self.modo_comercial_desativado_var.set(False)

    def toggle_modo_comercial_desativado(self):
        try:
            novo_estado = self.modo_comercial_desativado_var.get()
            valor = "1" if novo_estado else "0"
            with open(CAMINHO_BATOCERA, "r") as f:
                conteudo = f.read()

            tag = "MODO_COMERCIAL_DESATIVADO"
            nova_linha = f"{tag} = {valor}"

            if tag in conteudo:
                conteudo = re.sub(
                    rf"{re.escape(tag)}\s*=\s*[01]",
                    nova_linha,
                    conteudo
                )
            else:
                cabecalho = "# ------------ A0 - CONFIGURAÇÕES DO MODO COMERCIAL RETRO LUXXO----------- #"
                if cabecalho in conteudo:
                    conteudo = conteudo.replace(
                        cabecalho,
                        f"{cabecalho}\n{nova_linha}"
                    )
                else:
                    conteudo += f"\n{nova_linha}\n"

            with open(CAMINHO_BATOCERA, "w") as f:
                f.write(conteudo)

            # Só reinicia o fbneo_alpha.so se mudou de Free (True) para Comercial (False)
            if self.modo_comercial_atual != novo_estado:
                if self.modo_comercial_atual == True and novo_estado == False:
                    if hasattr(self, 'gateway_atual') and self.gateway_atual:
                        self.aplicar_arquivos_pix(self.gateway_atual)
                
                self.modo_comercial_atual = novo_estado

        except Exception as e:
            msgbox.showerror("Erro", f"Erro ao alterar MODO_COMERCIAL_DESATIVADO:\n{e}")

    # --- PROCESSOS ---
    def parar_processo(self, caminho):
        try:
            pids = subprocess.check_output(["pgrep", "-f", caminho]).decode().split()
            if pids:
                subprocess.run(["kill", "-9"] + pids)
        except:
            pass

    def iniciar_processo(self, caminho):
        try:
            subprocess.check_output(["pgrep", "-f", caminho])
        except subprocess.CalledProcessError:
            subprocess.Popen([caminho])

    # --- REINICIAR 'ONE' IMEDIATAMENTE ---
    def reiniciar_one(self):
        try:
            pids = subprocess.check_output(["pgrep", "-f", PROCESSO_ONE]).decode().split()
            if pids:
                subprocess.run(["kill", "-9"] + pids)
            subprocess.Popen([PROCESSO_ONE])
        except subprocess.CalledProcessError:
            subprocess.Popen([PROCESSO_ONE])
        except Exception as e:
            msgbox.showerror("Erro", f"Erro ao reiniciar 'one':\n{e}")

    # --- ENCERRAR PROCESSO COM SEGURANÇA ---
    def encerrar_processo(self, caminho):
        try:
            pids = subprocess.check_output(["pgrep", "-f", caminho]).decode().split()
            if not pids:
                return
            subprocess.run(["kill"] + pids)
            subprocess.run(["sleep", "1"])
            try:
                pids_restantes = subprocess.check_output(["pgrep", "-f", caminho]).decode().split()
                if pids_restantes:
                    subprocess.run(["kill", "-9"] + pids_restantes)
            except subprocess.CalledProcessError:
                pass 
        except subprocess.CalledProcessError:
            pass 
        except Exception as e:
            msgbox.showerror("Erro", f"Erro ao encerrar processo:\n{e}")

    # --- APLICAR MODO COMERCIAL DESATIVADO ---
    def aplicar_desativar_modo_comercial(self):
        self.encerrar_processo(PROCESSO_ONE)
        subprocess.run(["killall", "-9", "3ree"], stderr=subprocess.DEVNULL)
        subprocess.run(["killall", "-9", "R3ree"], stderr=subprocess.DEVNULL)

        try:
            if os.path.exists(CAMINHO_ES_INPUT_DEV):
                subprocess.run(["cp", "-f", CAMINHO_ES_INPUT_DEV, CAMINHO_ES_INPUT_DEST], check=True)
                subprocess.run(["/userdata/system/custom.sh"], check=True)
        except Exception as e:
            msgbox.showerror("Erro", f"Erro ao copiar es_input.cfg:\n{e}")

        try:
            if os.path.exists(EMULATORLAUNCHER) and not os.path.exists(EMULATORLAUNCHER_BKP):
                os.rename(EMULATORLAUNCHER, EMULATORLAUNCHER_BKP)
        except Exception as e:
            msgbox.showerror("Erro", f"Erro ao mover emulatorlauncher:\n{e}")

        try:
            if os.path.exists(EMULATORLAUNCHER_PY):
                shutil.move(EMULATORLAUNCHER_PY, EMULATORLAUNCHER_USR)
        except Exception as e:
            msgbox.showerror("Erro", f"Erro ao mover emulatorlauncher.py:\n{e}")

        try:
            subprocess.run(["cp", "-f", RETROARCH_HACK_1, RETROARCH_HACK_DEST], check=True)
        except Exception as e:
            msgbox.showerror("Erro", "Erro ao copiar retroarch hack 1: " + str(e))

        subprocess.run(["batocera-save-overlay"], env={**os.environ, "PATH": "/usr/bin:/bin:/sbin:/usr/sbin:" + os.environ.get("PATH", "")})

    # --- RESTAURAR MODO COMERCIAL ---
    def restaurar_modo_comercial(self):
        try:
            if os.path.exists(EMULATORLAUNCHER_USR):
                shutil.move(EMULATORLAUNCHER_USR, EMULATORLAUNCHER_PY)
        except Exception as e:
            msgbox.showerror("Erro", f"Erro ao restaurar emulatorlauncher.py:\n{e}")

        try:
            if os.path.exists(EMULATORLAUNCHER_BKP):
                os.rename(EMULATORLAUNCHER_BKP, EMULATORLAUNCHER)
        except Exception as e:
            msgbox.showerror("Erro", f"Erro ao restaurar emulatorlauncher:\n{e}")

        try:
            subprocess.run(["cp", "-f", RETROARCH_HACK_0, RETROARCH_HACK_DEST], check=True)
        except Exception as e:
            msgbox.showerror("Erro", "Erro ao copiar retroarch hack 0: " + str(e))

        os.environ["PATH"] = BIN_DIR + ":" + os.environ.get("PATH", "")

        self.reiniciar_one()
        subprocess.Popen([PROCESSO_R3REE], cwd=BIN_DIR)
        subprocess.Popen([PROCESSO_3REE], cwd=BIN_DIR)
        subprocess.Popen([BIN_DIR + "/Launcher_off.sh"], cwd=BIN_DIR)

        subprocess.run(["batocera-save-overlay"])

    # --- CAMPOS ---
    def verificar_campos(self, event=None):
        if any([
            self.input_saida.get().strip(),
            self.input_creditos.get().strip(),
            self.input_menu.get().strip()
        ]):
            self.save_btn.configure(state="normal")
        else:
            self.save_btn.configure(state="disabled")

    # --- SALVAR CONFIGURAÇÕES COM REINÍCIO ---
    def salvar_config(self):
        try:
            with open(CAMINHO_BATOCERA, "r") as f:
                conteudo = f.read()

            if self.input_creditos.get():
                conteudo = re.sub(r"TEMPO_JOGO_MINUTOS\s*=\s*\d+",
                                  f"TEMPO_JOGO_MINUTOS = {self.input_creditos.get()}", conteudo)

            if self.input_saida.get():
                conteudo = re.sub(r"TEMPO_HOTKEY_SEGUNDOS\s*=\s*\d+",
                                  f"TEMPO_HOTKEY_SEGUNDOS = {self.input_saida.get()}", conteudo)

            if self.input_menu.get():
                conteudo = re.sub(r"TEMPO_MENU_SEGUNDOS\s*=\s*\d+",
                                  f"TEMPO_MENU_SEGUNDOS = {self.input_menu.get()}", conteudo)

            with open(CAMINHO_BATOCERA, "w") as f:
                f.write(conteudo)

            self.reiniciar_one()

            msgbox.showinfo("Sucesso", "CONFIGURAÇÕES SALVAS! ☕️")

        except Exception as e:
            msgbox.showerror("Erro", str(e))

    # --- FECHAR ---
    def fechar(self):
        try:
            subprocess.run(["killall", "-9", "pcmanfm", "emulationstation"])
        except:
            pass
        if self.modo_comercial_desativado_var.get():
            subprocess.run(["batocera-save-overlay"])
            self.aplicar_desativar_modo_comercial()
        else:
            subprocess.run(["batocera-save-overlay"])
            self.restaurar_modo_comercial()
        self.destroy()


