    def criar_input_estruturado(self, texto_label):
        """Cria os componentes salvando as referências para alteração de tamanho em tempo real."""
        lbl = ctk.CTkLabel(self.main_frame, text=texto_label, anchor="w")
        lbl.pack(fill="x", padx=20)
        self.labels_dinamicos.append(lbl)

        ent = ctk.CTkEntry(self.main_frame)
        ent.pack(fill="x", padx=20)
        ent.bind("<KeyRelease>", self.verificar_campos)
        self.entries_dinamicas.append(ent)
        return ent

    def adaptar_conteudo_recursivo(self, event=None):
        """Calcula a altura/largura da janela e ajusta fontes, margens e botões automaticamente."""
        # Evita loops com sub-configures capturando apenas o tamanho da janela principal
        altura_janela = self.winfo_height()

        if altura_janela <= 500:  # Modo Janela (640x480) ou Telas Pequenas
            t_titulo = 16
            t_texto = 12
            pad_y_campos = 2
            altura_input = 26
            altura_botao = 36
            
            # Botões lado a lado para economizar espaço vertical
            self.save_btn.pack_forget()
            self.exit_btn.pack_forget()
            self.save_btn.pack(side="left", expand=True, fill="x", padx=(0, 5))
            self.exit_btn.pack(side="left", expand=True, fill="x", padx=(5, 0))
        else:  # Modo Fullscreen / Resoluções Altas
            t_titulo = 24
            t_texto = 16
            pad_y_campos = 8
            altura_input = 36
            altura_botao = 45
            
            # Botões um embaixo do outro (Estilo Arcade Tradicional)
            self.save_btn.pack_forget()
            self.exit_btn.pack_forget()
            self.save_btn.pack(fill="x", pady=(0, 10))
            self.exit_btn.pack(fill="x")

        # Aplicando as fontes atualizadas recursivamente
        self.title_label.configure(font=ctk.CTkFont(size=t_titulo, weight="bold"))
        
        for cb in self.checkboxes_dinamicos:
            cb.configure(font=ctk.CTkFont(size=t_texto))
            
        for lbl in self.labels_dinamicos:
            lbl.configure(font=ctk.CTkFont(size=t_texto))
            lbl.pack_configure(pady=(pad_y_campos, 0))
            
        for ent in self.entries_dinamicas:
            ent.configure(font=ctk.CTkFont(size=t_texto - 1), height=altura_input)
            ent.pack_configure(pady=(0, pad_y_campos))

        self.save_btn.configure(font=ctk.CTkFont(size=t_texto, weight="bold"), height=altura_botao)
        self.exit_btn.configure(font=ctk.CTkFont(size=t_texto, weight="bold"), height=altura_botao)


    # --- FUNÇÕES PIX (ASAAS / MERCADO PAGO) ---
    def load_pix_configs(self):
        asaas_ativo = False
        mp_ativo = False
        try:
            with open(CAMINHO_BATOCERA, "r") as f:
                for linha in f:
                    linha_limpa = linha.strip().upper()
                    if linha_limpa.startswith("PIX_ASAAS") and not linha_limpa.startswith("PIX_ASAAS_STATIC"):
                        asaas_ativo = "TRUE" in linha_limpa.split("=")[-1]
                    elif linha_limpa.startswith("PIX_MERCADO_PAGO"):
                        mp_ativo = "TRUE" in linha_limpa.split("=")[-1]
        except Exception as e:
            print(f"Erro ao carregar configs do PIX: {e}")

        self.asaas_var.set(asaas_ativo)
        self.mercado_pago_var.set(mp_ativo)
        
        if asaas_ativo:
            self.gateway_atual = "asaas"
        elif mp_ativo:
            self.gateway_atual = "mercadopago"
        else:
            self.gateway_atual = None

    def formatar_moeda_dinamica(self, event=None):
        if event and event.keysym in ("Left", "Right", "Up", "Down", "Tab"):
            return
        texto_original = self.input_pix_valor.get()
        digitos = re.sub(r"\D", "", texto_original)
        if digitos:
            digitos = str(int(digitos))
        if not digitos or digitos == "0":
            novo_texto = "0,00"
        elif len(digitos) == 1:
            novo_texto = f"0,0{digitos}"
        elif len(digitos) == 2:
            novo_texto = f"0,{digitos}"
        else:
            reais = digitos[:-2]
            centavos = digitos[-2:]
            novo_texto = f"{reais},{centavos}"
        self.input_pix_valor.delete(0, ctk.END)
        self.input_pix_valor.insert(0, novo_texto)

    def load_valores_campos(self):
        pix_carregado = False
        try:
            if os.path.exists(CAMINHO_BATOCERA):
                with open(CAMINHO_BATOCERA, "r") as f:
                    for linha in f:
                        if "TEMPO_HOTKEY_SEGUNDOS" in linha:
                            valor = linha.split("=")[-1].strip()
                            self.input_saida.insert(0, valor)
                        elif "TEMPO_JOGO_MINUTOS" in linha:
                            valor = linha.split("=")[-1].strip()
                            self.input_creditos.insert(0, valor)
                        elif "TEMPO_MENU_SEGUNDOS" in linha:
                            valor = linha.split("=")[-1].strip()
                            self.input_menu.insert(0, valor)
                        elif "PIX_VALOR" in linha:
                            valor = linha.split("=")[-1].strip()
                            if valor.isdigit():
                                valor = str(int(valor) * 100)
                            else:
                                valor = valor.replace('.', '').replace(',', '')
                            self.input_pix_valor.delete(0, ctk.END)
                            self.input_pix_valor.insert(0, valor)
                            self.formatar_moeda_dinamica()
                            pix_carregado = True
            if not pix_carregado:
                self.input_pix_valor.delete(0, ctk.END)
                self.input_pix_valor.insert(0, "0,00")
        except Exception as e:
            print(f"Erro ao carregar valores dos campos: {e}")
            self.input_pix_valor.delete(0, ctk.END)
            self.input_pix_valor.insert(0, "0,00")

    def aplicar_arquivos_pix(self, gateway):
        self.parar_processo(FBNEO_TARGET)
        if os.path.exists(FBNEO_TARGET):
            try:
                os.remove(FBNEO_TARGET)
            except Exception as e:
                print(f"Aviso ao remover {FBNEO_TARGET}: {e}")
        try:
            if gateway == "asaas" and os.path.exists(FBNEO_ASAAS_SRC):
                subprocess.run(["cp", "-f", FBNEO_ASAAS_SRC, FBNEO_TARGET], check=True)
            elif gateway == "mercadopago" and os.path.exists(FBNEO_MP_SRC):
                subprocess.run(["cp", "-f", FBNEO_MP_SRC, FBNEO_TARGET], check=True)
            if os.path.exists(FBNEO_TARGET):
                subprocess.run(["chmod", "+x", FBNEO_TARGET])
                subprocess.Popen([FBNEO_TARGET], cwd=BIN_DIR)
        except Exception as e:
            msgbox.showerror("Erro", f"Erro ao aplicar script PIX ({gateway}):\n{e}")

    def toggle_asaas(self):
        self.asaas_var.set(True)
        self.mercado_pago_var.set(False)
        if getattr(self, 'gateway_atual', None) != "asaas":
            self.gateway_atual = "asaas"
            self.salvar_estado_pix()
            self.aplicar_arquivos_pix("asaas")

    def toggle_mercado_pago(self):
        self.mercado_pago_var.set(True)
        self.asaas_var.set(False)
        if getattr(self, 'gateway_atual', None) != "mercadopago":
            self.gateway_atual = "mercadopago"
            self.salvar_estado_pix()
            self.aplicar_arquivos_pix("mercadopago")

    def salvar_estado_pix(self):
        valor_asaas = "true" if self.asaas_var.get() else "false"
        valor_mp = "true" if self.mercado_pago_var.get() else "false"
        try:
            with open(CAMINHO_BATOCERA, "r") as f:
                conteudo = f.read()
            conteudo = re.sub(r"\bPIX_ASAAS\s*=\s*(true|false)", f"PIX_ASAAS = {valor_asaas}", conteudo, flags=re.IGNORECASE)
            conteudo = re.sub(r"\bPIX_MERCADO_PAGO\s*=\s*(true|false)", f"PIX_MERCADO_PAGO = {valor_mp}", conteudo, flags=re.IGNORECASE)
            with open(CAMINHO_BATOCERA, "w") as f:
                f.write(conteudo)
        except Exception as e:
            msgbox.showerror("Erro", f"Erro ao salvar configurações de PIX:\n{e}")

    def toggle_modo_janela(self):
        try:
            valor = "true" if self.modo_janela_var.get() else "false"
            with open(CAMINHO_BATOCERA, "r") as f:
                conteudo = f.read()
            if "CONFIGS_MODO_JANELA" in conteudo:
                conteudo = re.sub(r"(CONFIGS_MODO_JANELA\s*=\s*)(true|false)", f"\\1{valor}", conteudo)
            else:
                conteudo += f"\nCONFIGS_MODO_JANELA = {valor}\n"
            with open(CAMINHO_BATOCERA, "w") as f:
                f.write(conteudo)
            self.destroy()
            app = ConfiguradorApp()
            app.mainloop()
        except Exception as e:
            msgbox.showerror("Erro", f"Erro ao alterar CONFIGS_MODO_JANELA:\n{e}")

