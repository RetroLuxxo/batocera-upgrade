# Define os caminhos dos arquivos
ORIGEM="/userdata/system/configs/emulationstation/es_last_input.cfg"
DESTINO="/userdata/system/.dev/es_input.cfg"

# Verifica se o arquivo de origem existe
if [ -f "$ORIGEM" ]; then
    echo "Arquivo encontrado. Iniciando a cópia..."

    # 1. Armazena o conteúdo do controle (extrai apenas o bloco entre <inputConfig> e </inputConfig>)
    NOVO_CONTROLE=$(sed -n '/<inputConfig/,/<\/inputConfig>/p' "$ORIGEM")

    # Verifica se conseguiu ler algo
    if [ -z "$NOVO_CONTROLE" ]; then
        echo "Erro: O arquivo de origem estava vazio ou inválido."
        exit 1
    fi

    # 2. Faz backup do arquivo original antes de mexer
    cp "$DESTINO" "$DESTINO.backup_seguranca"

    # 3. Remove a última linha do arquivo de destino (que é o </inputList>) para abrir o arquivo
    sed -i '/<\/inputList>/d' "$DESTINO"

    # 4. Cola o novo controle no final do arquivo
    echo "$NOVO_CONTROLE" >> "$DESTINO"

    # 5. Fecha o arquivo novamente com a tag correta
    echo "</inputList>" >> "$DESTINO"

    # 6. Apaga o arquivo de origem (es_last_input.cfg)
    rm "$ORIGEM"

    echo "Pronto! Controle copiado e arquivo temporário apagado."
    echo "Se precisar desfazer, use: cp $DESTINO.backup_seguranca $DESTINO"

else
    echo "Nada a fazer: O arquivo $ORIGEM não existe no momento."
fi





