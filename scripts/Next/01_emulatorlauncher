##############################################################################
# CONFIGURAÇÕES GERAIS
##############################################################################

ARQ_TEMPO="/userdata/system/.dev/tempo_jogo.txt"
ARQ_SALDO="/userdata/system/.dev/saldo.txt"

SOM_AVISO="/userdata/system/.dev/efeitos_sonoros/insert_coin.plataforma.mp3"
SOM_COIN_TAITO="/userdata/system/.dev/efeitos_sonoros/coins-taito.mp3"

##############################################################################
# COPIA CONFIG INPUT
##############################################################################

cp -f /userdata/system/.dev/es_input.cfg /userdata/system/configs/emulationstation/

##############################################################################
# LIMPEZA DE SAVES
##############################################################################

SAVE_ROOT="/userdata/saves"
find "$SAVE_ROOT" -type f -regex '.*\.state[0-9]$' | while read -r file; do
    dir=$(dirname "$file")
    base=$(basename "$file")
    game="${base%%.state*}"

    saves=( $(ls -1t "$dir"/"$game".state[0-9] 2>/dev/null) )
    [[ ${#saves[@]} -eq 0 ]] && continue

    newest="${saves[0]}"
    auto_file="$dir/$game.state.auto"

    if [[ -f "$auto_file" ]]; then
        if [[ "$newest" -nt "$auto_file" ]]; then
            mv -f "$newest" "$auto_file"
        else
            newest="$auto_file"
        fi
    else
        mv -f "$newest" "$auto_file"
    fi

    for old in "${saves[@]}"; do
        [[ "$old" != "$newest" ]] && rm -f "$old"
    done
done

rm -f /userdata/system/configs/retroarch/retroarchcustom.cfg

##############################################################################
# LEITURA DE CONTADOR E SALDO
##############################################################################

count=$(cat /userdata/system/.dev/contador.txt 2>/dev/null)
count=${count:-0}

saldo_valor=0
if [ -f "$ARQ_SALDO" ]; then
    saldo_valor=$(cat "$ARQ_SALDO" 2>/dev/null)
    saldo_valor=${saldo_valor:-0}
fi

##############################################################################
# 3. CONSOLES (MODO TEMPO)
##############################################################################

# BLOQUEIO: se contador <= 0 E saldo <= 0 → não inicia
if [ "${count:-0}" -le 0 ] && [ "${saldo_valor:-0}" -le 0 ]; then
    Launcher_off.sh
    mpv /userdata/system/.dev/efeitos_sonoros/insert_coin.wav > /dev/null 2>&1
    exit 0
fi

SALDO_EXISTENTE=0

# Se houver saldo > 0 → usa saldo
if [ "${saldo_valor:-0}" -gt 0 ]; then
    echo "$saldo_valor" > "$ARQ_TEMPO"
    SALDO_EXISTENTE=1
fi

# Se não houver saldo → usa contador
if [ "$SALDO_EXISTENTE" -eq 0 ]; then

    count=$((count - 1))
    echo "$count" > /userdata/system/.dev/contador.txt

    CAMINHO_COIN="/userdata/system/batocera.conf"

    if [ -f "$CAMINHO_COIN" ]; then
        TEMPO_JOGO_MINUTOS=$(grep -oP 'TEMPO_JOGO_MINUTOS\s*=\s*\K\d+' "$CAMINHO_COIN")
    fi

    TEMPO_JOGO_MINUTOS=${TEMPO_JOGO_MINUTOS:-15}
    TEMPO_JOGO_SEGUNDOS=$((TEMPO_JOGO_MINUTOS * 60))

    echo "$TEMPO_JOGO_SEGUNDOS" > "$ARQ_TEMPO"
    echo "$TEMPO_JOGO_SEGUNDOS" > "$ARQ_SALDO"
fi

##############################################################################
# FUNÇÃO DE ENCERRAMENTO FORÇADO (Quando o tempo esgota por completo)
##############################################################################

kill_emulador() {
    # 1. Derruba imediatamente a interface comercial do sistema
    killall -9 3ree 2>/dev/null
    killall -9 R3ree 2>/dev/null
    pkill -9 -f "3ree" 2>/dev/null
    pkill -9 -f "R3ree" 2>/dev/null

    # 2. Tenta enviar fecho de janela padrão
    xdotool key alt+F4 2>/dev/null
    sleep 0.4

    # 3. Derruba de forma agressiva os servidores do Wine e Proton para jogos de Windows Standalone
    killall -9 wineserver 2>/dev/null
    killall -9 wine 2>/dev/null
    pkill -9 -f "wine" 2>/dev/null
    pkill -9 -f "Proton" 2>/dev/null

    # 4. Encerra qualquer executável .exe órfão persistente em memória
    killall -9 fcadefbneo.exe 2>/dev/null
    killall -9 fcv39.exe 2>/dev/null
    killall -9 fcadesnes9x.exe 2>/dev/null
    killall -9 ggpofba-ng.exe 2>/dev/null
    pkill -9 -f "\.exe" 2>/dev/null

    # 5. Encerra outros emuladores standalone e backends de teclado
    killall -9 tecladovenv 2>/dev/null
    killall -9 fc2-electron 2>/dev/null
    killall -9 flycast.elf 2>/dev/null
    
    # 6. Limpeza e remoção das travas de tempo
    dkill 2>/dev/null
    rm -f /userdata/system/.dev/coin
    rm -f /userdata/system/.dev/tempo_jogo.txt
}

##############################################################################
# CONTADOR SINCRONIZADO
##############################################################################

decrementa_tempo_jogo() {

    #sleep 10

    local estava_abaixo_59=0

    while true; do

        [ ! -f "$ARQ_TEMPO" ] && break

        tempo=$(cat "$ARQ_TEMPO" 2>/dev/null)
        tempo=${tempo:-0}

        # 🔔 Toca se entrar na zona <=59 (inclusive se já começar nela)
        if [ "$tempo" -le 59 ] && [ "$tempo" -gt 0 ] && [ "$estava_abaixo_59" -eq 0 ]; then
            echo "" > /userdata/system/.dev/configs/qr
            mpv "$SOM_AVISO" > /dev/null 2>&1 &
            estava_abaixo_59=1
        fi

        # 🔄 Reset se sair da zona (ex: ganhou tempo)
        if [ "$tempo" -gt 59 ]; then
            estava_abaixo_59=0
            rm -f /userdata/system/.dev/configs/qr
        fi

        if [ "$tempo" -le 0 ]; then
            echo "0" > "$ARQ_TEMPO"
            echo "0" > "$ARQ_SALDO"
            kill_emulador
            break
        fi

        tempo=$((tempo - 1))

        echo "$tempo" > "$ARQ_TEMPO.tmp" && mv "$ARQ_TEMPO.tmp" "$ARQ_TEMPO"
        echo "$tempo" > "$ARQ_SALDO.tmp" && mv "$ARQ_SALDO.tmp" "$ARQ_SALDO"

        sleep 1
    done
}

##############################################################################
# INICIA JOGO + OVERLAY + CONTADOR
##############################################################################

/usr/lib/python3.11/site-packages/configgen/emulatorlauncher.py "$@" &
game_pid=$!

2wo &
pkill unclutter &
# Mata qualquer instância antiga do contador
pkill -f decrementa_tempo_jogo 2>/dev/null

# --- BUSCA DELAY NO BATOCERA.CONF ---
BATOCERA_CONF="/userdata/system/batocera.conf"
TEMPO_DELAY_TIMER_SEGUNDOS=$(grep -E '^[[:space:]]*TEMPO_DELAY_TIMER_SEGUNDOS[[:space:]]*=' "$BATOCERA_CONF" \
    | tail -n 1 | cut -d'=' -f2 | tr -d '[:space:]')

# Se não estiver definido ou inválido, usa 5 segundos
if ! [[ "$TEMPO_DELAY_TIMER_SEGUNDOS" =~ ^[0-9]+$ ]]; then
    TEMPO_DELAY_TIMER_SEGUNDOS=5
fi

# --- DELAY ANTES DE INICIAR O CONTADOR ---
sleep "$TEMPO_DELAY_TIMER_SEGUNDOS"
decrementa_tempo_jogo &
timer_pid=$!
trap '
    kill "$timer_pid" 2>/dev/null
' EXIT

# Aguarda o fim do jogo de forma normal
wait $game_pid

# --- MODIFICAÇÃO PRINCIPAL: REMOVE ARQUIVOS AO ENCERRAR NORMALMENTE ---
Launcher_off.sh
rm -f /userdata/system/.dev/configs/qr
rm -f /userdata/system/.dev/coin
rm -f /userdata/system/.dev/tempo_jogo.txt
exit 0
