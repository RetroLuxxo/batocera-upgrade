###### TESTE LOOP CHAVES API

CONF="/userdata/system/batocera.conf"
OUT="/usr/lib/liblinuxenv.so"

while true; do

    PIX_KEY=$(grep '^PIX_KEY' "$CONF" | sed 's/^[^"]*"\(.*\)".*/\1/')
    PIX_KEY=$(echo "$PIX_KEY" | tr -d '\r' | sed 's/^ *//; s/ *$//')

    # se vazio, aguarda próxima verificação
    [ -z "$PIX_KEY" ] && {
        sleep 10
        continue
    }

    ASAAS_VAL=""
    MP_VAL=""

    if [ -f "$OUT" ]; then
        ASAAS_VAL=$(grep '^ASAAS_ACCESS_TOKEN' "$OUT" | head -n1 | sed 's/^[^=]*=[ ]*//')
        MP_VAL=$(grep '^MP_ACCESS_TOKEN' "$OUT" | head -n1 | sed 's/^[^=]*=[ ]*//')
    fi

    case "$PIX_KEY" in
        \$aact_prod_*)
            ASAAS_VAL="$PIX_KEY"
            ;;
        APP_USR-*)
            MP_VAL="$PIX_KEY"
            ;;
        *)
            ASAAS_VAL="$PIX_KEY"
            MP_VAL="$PIX_KEY"
            ;;
    esac

    {
        echo "ASAAS_ACCESS_TOKEN = $ASAAS_VAL"
        echo "MP_ACCESS_TOKEN = $MP_VAL"
    } > "$OUT"

    # limpa o PIX_KEY para evitar processar novamente
    sed -i 's|^\(PIX_KEY[ ]*=[ ]*\)".*"|\1""|' "$CONF"

    batocera-save-overlay 250

    sleep 10

done
